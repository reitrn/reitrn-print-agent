{
  "name": "reitrn-print-agent",
  "version": "1.0.1",
  "description": "reitrn. Print Agent — local USB print server",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "firebase": "^10.12.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.reitrn.print-agent",
    "productName": "reitrn Print Agent",
    "copyright": "reitrn.",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "reitrn-Print-Agent-Setup.exe",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "firebase-listener.js",
      "printer.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
